# Git & editor junk
.git
.gitignore
.vscode
.idea

# Python caches
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache

# Environment files (injected at runtime via docker-compose)
.env

# Generated output / uploads (mounted as volumes)
output/
uploads/

# Frontend source (handled by separate frontend Dockerfile)
frontend/

# Dev venvs
backend/.venv
backend/venv
backend/tests/

# Large binary/media files not needed in image
*.mp4
*.zip

# Windows scripts
*.bat
*.md
