MODEL_PATH=assets/models/pose_landmarker_full.task

# ALL relative paths in this file resolve against the REPOSITORY ROOT
# (assets/ = repo-root inputs, output/ = repo-root artifacts).

# CLI/developer video source — set ONE of the following:
#   a) a video file, or
#   b) USE_WEBCAM=true to use the default camera.
# The WEB APP does not use this: it uploads videos (see POST /api/uploads).
# If VIDEO_PATH is empty AND USE_WEBCAM is false, the CLI cannot open a source.
VIDEO_PATH=assets/videos/demo.mp4
USE_WEBCAM=false
WEBCAM_INDEX=0

# Rendering / recording
DISPLAY_MAX_WIDTH=1280
SAVE_OUTPUT=true
OUTPUT_PATH=output/videos/result.mp4

# Session Analytics
# Frame rate used to convert per-repetition frame spans into durations
# (seconds) in the generated SessionSummary. Match the source video / camera
# fps for accurate timing stats.
ANALYTICS_FPS=25.0

# 3D Mode
USE_3D=true
ENABLE_SMOOTHING=true

# Session Export
# Persist a SessionReport (produced by the analytics module) after each run
# under EXPORT_DIR (repo-root-relative → <repo-root>/output/sessions).
EXPORT_SESSION=true
EXPORT_FORMAT=json
EXPORT_DIR=output/sessions
