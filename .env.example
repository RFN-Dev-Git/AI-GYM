MODEL_PATH=assets/models/pose_landmarker_full.task

# Video source — set ONE of the following:
#   a) a video file, or
#   b) USE_WEBCAM=true to use the default camera.
# If VIDEO_PATH is empty AND USE_WEBCAM is false, the app cannot open a source.
VIDEO_PATH=assets/videos/demo.mp4
USE_WEBCAM=false
WEBCAM_INDEX=0

# Rendering / recording
DISPLAY_MAX_WIDTH=1280
SAVE_OUTPUT=true
OUTPUT_PATH=output/videos/result.mp4

# Session Analytics
# Frame rate used to convert per-repetition frame spans into durations
# (seconds) in the generated SessionSummary. Match the source video / camera
# fps for accurate timing stats.
ANALYTICS_FPS=25

# Session Export
# Persist a SessionSummary (produced by the analytics module) after each run.
# Enable with EXPORT_SESSION=true; choose "json" or "csv" output.
EXPORT_SESSION=true
EXPORT_FORMAT=json
EXPORT_DIR=output/sessions
