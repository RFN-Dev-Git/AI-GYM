MODEL_PATH=src/assets/models/pose_landmarker_lite.task


# Video source — set ONE of the following:
#   a) a video file, or
#   b) USE_WEBCAM=true to use the default camera.
# If VIDEO_PATH is empty AND USE_WEBCAM is false, the app cannot open a source.
VIDEO_PATH=src/assets/videos/demo.mp4
USE_WEBCAM=false
WEBCAM_INDEX=0

# Rendering / recording
DISPLAY_MAX_WIDTH=1280
SAVE_OUTPUT=false
OUTPUT_PATH=./output/result.mp4
